# Server mode: direct MySQL access, no SSH tunnel.
MYSQL_DIRECT=yes
MARKET_MYSQL_DIRECT=yes
TEST1_MYSQL_DIRECT=yes

# Optional local mode if direct access is unavailable:
# MARKET_SSH_HOST=54.69.237.139
# MARKET_SSH_USER=ubuntu
# MARKET_SSH_KEY_PATH=/run/secrets/market_ssh_key
# MARKET_SSH_BATCH_MODE=yes

# test = original MySQL. Used for sr and ls source reads.
MARKET_MYSQL_HOST=xp.cluster-cdgqiwig2x00.us-west-2.rds.amazonaws.com
MARKET_MYSQL_PORT=3306
MARKET_MYSQL_USER=root
MARKET_MYSQL_PASSWORD=replace_me
MARKET_MYSQL_DB=

# test1 = new RDS. Used for thesports reads and team_mapping writes.
TEST1_MYSQL_HOST=test-db.cluster-cdgqiwig2x00.us-west-2.rds.amazonaws.com
TEST1_MYSQL_PORT=3306
TEST1_MYSQL_USER=root
TEST1_MYSQL_PASSWORD=replace_me

# Mapping DB on test1.
MAPPING_MYSQL_DB=team_mapping

# LLM
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_MODEL=deepseek-v4-flash
